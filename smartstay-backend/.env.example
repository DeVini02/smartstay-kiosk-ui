# Sem Docker: use SQLite (cria smartstay.db na pasta do projeto)
DATABASE_URL=sqlite:///./smartstay.db

# Com Docker / PostgreSQL:
# DATABASE_URL=postgresql+psycopg://smartstay:smartstay@localhost:5432/smartstay
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ENVIRONMENT=development
DEMO_MODE=true
# Set this in staging/production and send it as X-SmartStay-Key from the kiosk.
KIOSK_API_KEY=
